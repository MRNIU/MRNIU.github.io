---
import "../styles/timeline.css";

interface Props {
  event: {
    type: "pull_request";
    ts: string;
    repo: string;
    semantic: string | null;
    data: {
      number: number;
      title: string;
      state: string;
      body: string;
    };
  };
}

const { event } = Astro.props;
const { data, repo, semantic, ts } = event;

const badgeClass: Record<string, string> = {
  merged: "state-badge--merged",
  open: "state-badge--open",
  closed: "state-badge--closed",
};

const time = new Date(ts).toLocaleString("en-US", {
  month: "short",
  day: "numeric",
  hour: "2-digit",
  minute: "2-digit",
});

const truncatedBody = data.body.length > 200
  ? data.body.slice(0, 200) + "..."
  : data.body;

const prUrl = `https://github.com/${repo}/pull/${data.number}`;
const repoUrl = `https://github.com/${repo}`;
---

<div class="event-card" data-semantic={semantic}>
  <div style="display: flex; align-items: baseline; gap: 6px; flex-wrap: wrap;">
    <span class={`state-badge ${badgeClass[data.state] || 'state-badge--open'}`}>{data.state}</span>
    <a class="event-ref" href={prUrl} target="_blank" rel="noopener">#{data.number}</a>
    <span style="color: var(--cp-fg-bright);">{data.title}</span>
  </div>
  {truncatedBody && (
    <p class="event-body" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
      {truncatedBody}
    </p>
  )}
  <div style="display: flex; gap: 10px; margin-top: 2px;">
    <a class="event-repo" href={repoUrl} target="_blank" rel="noopener">{repo}</a>
    <span class="event-time">{time}</span>
  </div>
</div>
