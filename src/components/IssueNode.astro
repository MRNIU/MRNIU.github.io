---
import "../styles/timeline.css";

interface Props {
  event: {
    type: "issue";
    ts: string;
    repo: string;
    semantic: string | null;
    data: {
      number: number;
      title: string;
      state: string;
      body: string;
    };
  };
}

const { event } = Astro.props;
const { data, repo, ts } = event;

const isOpen = data.state === "open";
const stateColor = isOpen ? "#238636" : "#8957e5";
const stateIcon = isOpen ? "\u25CB" : "\u25CF"; // open circle / filled circle

const time = new Date(ts).toLocaleString("en-US", {
  month: "short",
  day: "numeric",
  hour: "2-digit",
  minute: "2-digit",
});

const truncatedBody = data.body.length > 200
  ? data.body.slice(0, 200) + "..."
  : data.body;
---

<div class="event-card">
  <div style="display: flex; align-items: baseline; gap: 8px; flex-wrap: wrap;">
    <span style={`color: ${stateColor}; font-weight: 600;`}>{stateIcon}</span>
    <span style="font-weight: 600;">#{data.number} {data.title}</span>
  </div>
  <p class="color-fg-muted text-small" style="margin: 6px 0 4px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
    {truncatedBody}
  </p>
  <div style="display: flex; gap: 12px;">
    <span class="event-repo">{repo}</span>
    <span class="event-time">{time}</span>
  </div>
</div>
