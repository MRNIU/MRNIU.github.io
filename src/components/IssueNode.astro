---
import "../styles/timeline.css";

interface Props {
  event: {
    type: "issue";
    ts: string;
    repo: string;
    semantic: string | null;
    data: {
      number: number;
      title: string;
      state: string;
      body: string;
    };
  };
}

const { event } = Astro.props;
const { data, repo, ts } = event;

const isOpen = data.state === "open";

const time = new Date(ts).toLocaleString("en-US", {
  month: "short",
  day: "numeric",
  hour: "2-digit",
  minute: "2-digit",
});

const truncatedBody = data.body.length > 200
  ? data.body.slice(0, 200) + "..."
  : data.body;

const issueUrl = `https://github.com/${repo}/issues/${data.number}`;
const repoUrl = `https://github.com/${repo}`;
---

<div class="event-card">
  <div style="display: flex; align-items: baseline; gap: 6px; flex-wrap: wrap;">
    <span class={`state-badge ${isOpen ? 'state-badge--open' : 'state-badge--merged'}`}>{isOpen ? 'open' : 'closed'}</span>
    <a class="event-ref" href={issueUrl} target="_blank" rel="noopener">#{data.number}</a>
    <span style="color: var(--cp-fg-bright);">{data.title}</span>
  </div>
  {truncatedBody && (
    <p class="event-body" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
      {truncatedBody}
    </p>
  )}
  <div style="display: flex; gap: 10px; margin-top: 2px;">
    <a class="event-repo" href={repoUrl} target="_blank" rel="noopener">{repo}</a>
    <span class="event-time">{time}</span>
  </div>
</div>
