---
interface MonthEntry {
  key: string;
  eventCount: number;
}

interface Props {
  months: MonthEntry[];
  activeMonth: string;
  labels?: {
    months?: string;
    filter?: string;
    eventTypes?: Record<string, string>;
  };
}

const { months, activeMonth, labels = {} } = Astro.props;

const eventTypeLabels = labels.eventTypes || {};
const eventTypes = [
  { value: "commit", label: eventTypeLabels.commit || "Commits" },
  { value: "pull_request", label: eventTypeLabels.pull_request || "Pull Requests" },
  { value: "review", label: eventTypeLabels.review || "Reviews" },
  { value: "issue", label: eventTypeLabels.issue || "Issues" },
  { value: "issue_comment", label: eventTypeLabels.issue_comment || "Comments" },
  { value: "ai_roast", label: eventTypeLabels.ai_roast || "AI Roasts" },
];

function formatMonth(key: string): string {
  const [year, month] = key.split("-");
  const date = new Date(parseInt(year), parseInt(month) - 1);
  return date.toLocaleDateString("en-US", { year: "numeric", month: "short" });
}
---
<aside class="sidebar" id="sidebar">
  <div class="sidebar-section">
    <h3>{labels.months || "Months"}</h3>
    <nav class="month-nav">
      {months.map((m) => (
        <button
          class={`month-btn ${m.key === activeMonth ? 'active' : ''}`}
          data-month={m.key}
          data-file={m.key + '.json'}
        >
          <span>{formatMonth(m.key)}</span>
          <span class="Counter">{m.eventCount}</span>
        </button>
      ))}
    </nav>
  </div>

  <div class="sidebar-section" style="margin-top: 12px; padding-top: 8px; border-top: 1px solid var(--cp-border-muted);">
    <h3>{labels.filter || "Filter"}</h3>
    <div class="filter-list">
      {eventTypes.map((t) => (
        <label class="filter-item">
          <input type="checkbox" checked data-filter-type={t.value} />
          <span>{t.label}</span>
        </label>
      ))}
    </div>
  </div>
</aside>
