---
interface Props {
  stats: {
    totalCommits: number;
    totalPRs: number;
    totalReviews: number;
    totalIssues: number;
    totalComments: number;
    activeRepos: number;
  };
  labels?: {
    commits?: string;
    prs?: string;
    reviews?: string;
    issues?: string;
    comments?: string;
    repos?: string;
  };
}

const { stats, labels = {} } = Astro.props;

const cards = [
  { value: stats.totalCommits, label: labels.commits || "Commits" },
  { value: stats.totalPRs, label: labels.prs || "Pull Requests" },
  { value: stats.totalReviews, label: labels.reviews || "Reviews" },
  { value: stats.totalIssues, label: labels.issues || "Issues" },
  { value: stats.totalComments, label: labels.comments || "Comments" },
  { value: stats.activeRepos, label: labels.repos || "Active Repos" },
];
---

<section class="dashboard-grid" style="padding: 24px 0;">
  <div class="dashboard-cards">
    {cards.map((card) => (
      <div class="Box p-3 text-center">
        <div class="f00 color-fg-default" data-countup={card.value}>0</div>
        <div class="text-small color-fg-muted">{card.label}</div>
      </div>
    ))}
  </div>
</section>

<style>
  .dashboard-cards {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 12px;
  }

  @media (max-width: 768px) {
    .dashboard-cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

<script>
  document.querySelectorAll('[data-countup]').forEach(el => {
    const target = parseInt(el.getAttribute('data-countup')!, 10);
    const duration = 1500;
    const start = performance.now();
    function update(now: number) {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      el.textContent = Math.floor(eased * target).toLocaleString();
      if (progress < 1) requestAnimationFrame(update);
    }
    requestAnimationFrame(update);
  });
</script>
