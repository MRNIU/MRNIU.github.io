---
interface Props {
  stats: {
    totalCommits: number;
    totalPRs: number;
    totalReviews: number;
    totalIssues: number;
    totalComments: number;
    activeRepos: number;
  };
  labels?: {
    commits?: string;
    prs?: string;
    reviews?: string;
    issues?: string;
    comments?: string;
    repos?: string;
  };
}

const { stats, labels = {} } = Astro.props;

const cards = [
  { value: stats.totalCommits, label: labels.commits || "Commits" },
  { value: stats.totalPRs, label: labels.prs || "Pull Requests" },
  { value: stats.totalReviews, label: labels.reviews || "Reviews" },
  { value: stats.totalIssues, label: labels.issues || "Issues" },
  { value: stats.totalComments, label: labels.comments || "Comments" },
  { value: stats.activeRepos, label: labels.repos || "Active Repos" },
];
---

<section class="dashboard">
  {cards.map((card) => (
    <div class="dash-cell">
      <span class="dash-value" data-countup={card.value}>0</span>
      <span class="dash-label">{card.label}</span>
    </div>
  ))}
</section>

<style>
  .dashboard {
    display: flex;
    gap: 0;
    padding: 12px 0;
    border-top: 1px solid var(--cp-border);
    border-bottom: 1px solid var(--cp-border);
  }

  .dash-cell {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 8px 4px;
    border-right: 1px solid var(--cp-border-muted);
  }

  .dash-cell:last-child {
    border-right: none;
  }

  .dash-value {
    font-family: var(--cp-font-mono);
    font-size: 22px;
    font-weight: 600;
    color: var(--cp-fg-bright);
    letter-spacing: -0.5px;
  }

  .dash-label {
    font-family: var(--cp-font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--cp-fg-muted);
    margin-top: 2px;
  }

  @media (max-width: 768px) {
    .dashboard {
      flex-wrap: wrap;
    }
    .dash-cell {
      flex: 0 0 33.33%;
    }
    .dash-cell:nth-child(3) {
      border-right: none;
    }
  }
</style>

<script>
  document.querySelectorAll('[data-countup]').forEach(el => {
    const target = parseInt(el.getAttribute('data-countup')!, 10);
    const duration = 1200;
    const start = performance.now();
    function update(now: number) {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      el.textContent = Math.floor(eased * target).toLocaleString();
      if (progress < 1) requestAnimationFrame(update);
    }
    requestAnimationFrame(update);
  });
</script>
