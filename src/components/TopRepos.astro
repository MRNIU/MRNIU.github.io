---
interface Month {
  key: string;
  file: string;
  eventCount: number;
  repos: string[];
  breakdown: Record<string, number>;
}

interface Props {
  months: Month[];
}

const { months } = Astro.props;

// Use only the 3 most recent months
const recentMonths = months.slice(0, 3);
const repoCounts = new Map<string, number>();
for (const month of recentMonths) {
  if (month.repoBreakdown) {
    for (const [repo, count] of Object.entries(month.repoBreakdown)) {
      repoCounts.set(repo, (repoCounts.get(repo) || 0) + (count as number));
    }
  } else {
    for (const repo of month.repos) {
      repoCounts.set(repo, (repoCounts.get(repo) || 0) + 1);
    }
  }
}

const sorted = [...repoCounts.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 8);

const maxCount = sorted.length > 0 ? sorted[0][1] : 1;
const barColors = ['var(--cp-green)', 'var(--cp-blue)', 'var(--cp-purple)', 'var(--cp-red)', 'var(--cp-yellow)', 'var(--cp-green)', 'var(--cp-blue)', 'var(--cp-purple)'];
---

<section style="padding: 12px 0;">
  <h2 class="section-heading">Recent Repositories</h2>
  <div class="repo-list">
    {sorted.map(([repo, count], i) => {
      const pct = Math.round((count / maxCount) * 100);
      return (
        <div class="repo-item">
          <div class="repo-header">
            <span class="repo-dot" style={`background: ${barColors[i]};`} />
            <div class="repo-name-box">
              <a class="repo-name-text" href={`https://github.com/${repo}`} target="_blank" rel="noopener">{repo}</a>
            </div>
            <span class="repo-count">{count}</span>
          </div>
          <div class="repo-bar-track">
            <div class="repo-bar" style={`width: ${pct}%; background: ${barColors[i]};`} />
          </div>
        </div>
      );
    })}
  </div>
</section>

<style>
  .section-heading {
    font-family: var(--cp-font-mono);
    font-size: var(--cp-fs-label);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--cp-fg-muted);
    margin: 0 0 10px;
    font-weight: 400;
  }

  .repo-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .repo-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  /* ─── Header line: dot + name + count ─── */
  .repo-header {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .repo-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .repo-name-box {
    flex: 1;
    min-width: 0;
    overflow: hidden;
  }

  .repo-name-text {
    display: block;
    font-family: var(--cp-font-mono);
    font-size: var(--cp-fs-sm);
    color: var(--cp-fg-default);
    white-space: nowrap;
    text-decoration: none;
    width: fit-content;
    max-width: 100%;
  }

  .repo-name-box:hover .repo-name-text {
    color: var(--cp-blue);
    animation: scroll-name 4s linear infinite;
  }

  @keyframes scroll-name {
    0%, 15%  { transform: translateX(0); }
    85%, 100% { transform: translateX(calc(-100% + 200px)); }
  }

  .repo-count {
    font-family: var(--cp-font-mono);
    font-size: var(--cp-fs-xs);
    color: var(--cp-fg-muted);
    flex-shrink: 0;
  }

  /* ─── Proportional bar below ─── */
  .repo-bar-track {
    height: 4px;
    background: var(--cp-bg-raised);
  }

  .repo-bar {
    height: 100%;
    min-width: 3px;
    transition: width 0.3s ease;
  }
</style>
