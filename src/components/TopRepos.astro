---
interface Month {
  key: string;
  file: string;
  eventCount: number;
  repos: string[];
  breakdown: Record<string, number>;
}

interface Props {
  months: Month[];
}

const { months } = Astro.props;

const repoCounts = new Map<string, number>();
for (const month of months) {
  const perRepo = month.eventCount / (month.repos.length || 1);
  for (const repo of month.repos) {
    repoCounts.set(repo, (repoCounts.get(repo) || 0) + Math.round(perRepo));
  }
}

const sorted = [...repoCounts.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 5);

const maxCount = sorted.length > 0 ? sorted[0][1] : 1;
const barColors = ['var(--cp-green)', 'var(--cp-blue)', 'var(--cp-purple)', 'var(--cp-red)', 'var(--cp-yellow)'];
---

<section style="padding: 12px 0;">
  <h2 class="section-heading">Top Repositories</h2>
  <div class="repo-list">
    {sorted.map(([repo, count], i) => (
      <div class="repo-row">
        <span class="repo-name">{repo}</span>
        <div class="repo-bar-track">
          <div class="repo-bar" style={`width: ${(count / maxCount) * 100}%; background: ${barColors[i]};`} />
        </div>
        <span class="repo-count">{count}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .section-heading {
    font-family: var(--cp-font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--cp-fg-muted);
    margin: 0 0 8px;
    font-weight: 400;
  }

  .repo-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .repo-row {
    display: grid;
    grid-template-columns: 200px 1fr 40px;
    align-items: center;
    gap: 10px;
    padding: 2px 0;
  }

  .repo-name {
    font-family: var(--cp-font-mono);
    font-size: 13px;
    color: var(--cp-fg-default);
    text-align: right;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .repo-bar-track {
    height: 4px;
    background: var(--cp-bg-raised);
  }

  .repo-bar {
    height: 100%;
    min-width: 2px;
    transition: width 0.3s ease;
  }

  .repo-count {
    font-family: var(--cp-font-mono);
    font-size: 12px;
    color: var(--cp-fg-muted);
    text-align: right;
  }

  @media (max-width: 768px) {
    .repo-row {
      grid-template-columns: 120px 1fr 36px;
    }
    .repo-name {
      font-size: 12px;
    }
  }
</style>
