---
interface Month {
  key: string;
  file: string;
  eventCount: number;
  repos: string[];
  breakdown: Record<string, number>;
}

interface Props {
  months: Month[];
}

const { months } = Astro.props;

const repoCounts = new Map<string, number>();
for (const month of months) {
  const perRepo = month.eventCount / (month.repos.length || 1);
  for (const repo of month.repos) {
    repoCounts.set(repo, (repoCounts.get(repo) || 0) + Math.round(perRepo));
  }
}

const sorted = [...repoCounts.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 5);

const barColors = ['var(--cp-green)', 'var(--cp-blue)', 'var(--cp-purple)', 'var(--cp-red)', 'var(--cp-yellow)'];
---

<section style="padding: 12px 0;">
  <h2 class="section-heading">Top Repositories</h2>
  <div class="repo-list">
    {sorted.map(([repo, count], i) => (
      <div class="repo-row">
        <div class="repo-name-box">
          <a class="repo-name-text" href={`https://github.com/${repo}`} target="_blank" rel="noopener">{repo}</a>
        </div>
        <div class="repo-bar" style={`background: ${barColors[i]};`} />
        <span class="repo-count">{count}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .section-heading {
    font-family: var(--cp-font-mono);
    font-size: var(--cp-fs-label);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--cp-fg-muted);
    margin: 0 0 8px;
    font-weight: 400;
  }

  .repo-list {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .repo-row {
    display: grid;
    grid-template-columns: 30% 1fr auto;
    align-items: center;
    gap: 12px;
    padding: 3px 0;
  }

  /* ─── Name: right-aligned, scroll on hover ─── */
  .repo-name-box {
    overflow: hidden;
    text-align: right;
    direction: rtl; /* makes overflow clip from left, text stays right-aligned */
  }

  .repo-name-text {
    display: inline-block;
    direction: ltr;
    font-family: var(--cp-font-mono);
    font-size: var(--cp-fs-sm);
    color: var(--cp-fg-default);
    white-space: nowrap;
    text-decoration: none;
  }

  .repo-name-box:hover .repo-name-text {
    color: var(--cp-blue);
    animation: scroll-name 4s linear infinite;
  }

  @keyframes scroll-name {
    0%   { transform: translateX(0); }
    15%  { transform: translateX(0); }
    85%  { transform: translateX(var(--scroll-dist, -40%)); }
    100% { transform: translateX(var(--scroll-dist, -40%)); }
  }

  /* ─── Bar: full width, same length, only color differs ─── */
  .repo-bar {
    height: 5px;
  }

  /* ─── Count ─── */
  .repo-count {
    font-family: var(--cp-font-mono);
    font-size: var(--cp-fs-xs);
    color: var(--cp-fg-muted);
    text-align: right;
    min-width: 3ch;
  }

  @media (max-width: 768px) {
    .repo-row {
      grid-template-columns: 40% 1fr auto;
    }
  }
</style>
