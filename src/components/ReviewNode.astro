---
import "../styles/timeline.css";

interface Props {
  event: {
    type: "review";
    ts: string;
    repo: string;
    semantic: string | null;
    data: {
      prNumber: number;
      prTitle: string;
      state: string;
      body: string;
      inlineComments: Array<{
        path: string;
        line: number;
        body: string;
      }>;
    };
  };
}

const { event } = Astro.props;
const { data, repo, ts } = event;

const stateConfig: Record<string, { bg: string; fg: string; label: string }> = {
  APPROVED: { bg: "#238636", fg: "#fff", label: "Approved" },
  CHANGES_REQUESTED: { bg: "#da3633", fg: "#fff", label: "Changes Requested" },
  COMMENTED: { bg: "#768390", fg: "#fff", label: "Commented" },
};

const config = stateConfig[data.state] || stateConfig.COMMENTED;

const time = new Date(ts).toLocaleString("en-US", {
  month: "short",
  day: "numeric",
  hour: "2-digit",
  minute: "2-digit",
});
---

<div class="event-card">
  <div style="display: flex; align-items: baseline; gap: 8px; flex-wrap: wrap;">
    <span
      style={`display: inline-block; padding: 1px 8px; border-radius: 12px; font-size: 12px; font-weight: 600; background: ${config.bg}; color: ${config.fg};`}
    >
      {config.label}
    </span>
    <span style="font-weight: 600;">#{data.prNumber} {data.prTitle}</span>
  </div>
  <p class="color-fg-muted text-small" style="margin: 6px 0 4px;">
    {data.body}
  </p>
  {data.inlineComments && data.inlineComments.length > 0 && (
    <div style="margin-top: 8px;">
      {data.inlineComments.map((comment) => (
        <div class="review-inline">
          <div class="mono text-small color-fg-muted" style="margin-bottom: 4px;">
            {comment.path}:{comment.line}
          </div>
          <div>{comment.body}</div>
        </div>
      ))}
    </div>
  )}
  <div style="display: flex; gap: 12px; margin-top: 4px;">
    <span class="event-repo">{repo}</span>
    <span class="event-time">{time}</span>
  </div>
</div>
