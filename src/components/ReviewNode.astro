---
import "../styles/timeline.css";

interface Props {
  event: {
    type: "review";
    ts: string;
    repo: string;
    semantic: string | null;
    data: {
      prNumber: number;
      prTitle: string;
      state: string;
      body: string;
      inlineComments: Array<{
        path: string;
        line: number;
        body: string;
      }>;
    };
  };
}

const { event } = Astro.props;
const { data, repo, ts } = event;

const badgeClass: Record<string, string> = {
  APPROVED: "state-badge--approved",
  CHANGES_REQUESTED: "state-badge--changes",
  COMMENTED: "state-badge--commented",
};

const badgeLabel: Record<string, string> = {
  APPROVED: "approved",
  CHANGES_REQUESTED: "changes",
  COMMENTED: "commented",
};

const time = new Date(ts).toLocaleString("en-US", {
  month: "short",
  day: "numeric",
  hour: "2-digit",
  minute: "2-digit",
});

const prUrl = `https://github.com/${repo}/pull/${data.prNumber}`;
const repoUrl = `https://github.com/${repo}`;
---

<div class="event-card event-card--indented">
  <div style="display: flex; align-items: baseline; gap: 6px; flex-wrap: wrap;">
    <span class={`state-badge ${badgeClass[data.state] || 'state-badge--commented'}`}>{badgeLabel[data.state] || data.state}</span>
    <a class="event-ref" href={prUrl} target="_blank" rel="noopener">#{data.prNumber}</a>
    <span>{data.prTitle}</span>
  </div>
  {data.body && (
    <p class="event-body">{data.body}</p>
  )}
  {data.inlineComments && data.inlineComments.length > 0 && (
    <div style="margin-top: 4px;">
      {data.inlineComments.map((comment) => (
        <div class="review-inline">
          <code>{comment.path}:{comment.line}</code>
          <div style="color: var(--cp-fg-subtle); margin-top: 2px;">{comment.body}</div>
        </div>
      ))}
    </div>
  )}
  <div style="display: flex; gap: 10px; margin-top: 2px;">
    <a class="event-repo" href={repoUrl} target="_blank" rel="noopener">{repo}</a>
    <span class="event-time">{time}</span>
  </div>
</div>
