---
interface Month {
  key: string;
  eventCount: number;
}

interface Props {
  months: Month[];
}

const { months } = Astro.props;

// Build a map of month -> event count from input data
const monthEventMap = new Map<string, number>();
for (const m of months) {
  monthEventMap.set(m.key, m.eventCount);
}

// Generate 52 weeks x 7 days of synthesized activity data
// Go back 52 weeks from today (2026-03-30)
const today = new Date("2026-03-30");
const cellSize = 11;
const cellGap = 3;
const totalSize = cellSize + cellGap;

interface DayData {
  date: Date;
  count: number;
  week: number;
  day: number;
}

const days: DayData[] = [];

// Start from the Sunday 52 weeks ago
const startDate = new Date(today);
startDate.setDate(startDate.getDate() - (52 * 7) - startDate.getDay());

for (let w = 0; w < 52; w++) {
  for (let d = 0; d < 7; d++) {
    const date = new Date(startDate);
    date.setDate(date.getDate() + w * 7 + d);

    // Only include dates up to today
    if (date > today) continue;

    const monthKey = `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, "0")}`;
    const monthEvents = monthEventMap.get(monthKey) || 0;

    // Distribute monthly events across days with some randomness (seeded by date)
    const daysInMonth = new Date(date.getFullYear(), date.getMonth() + 1, 0).getDate();
    const avgPerDay = monthEvents / daysInMonth;

    // Simple pseudo-random based on date
    const seed = date.getFullYear() * 10000 + (date.getMonth() + 1) * 100 + date.getDate();
    const pseudoRandom = ((seed * 9301 + 49297) % 233280) / 233280;
    const count = monthEvents > 0 ? Math.round(avgPerDay * pseudoRandom * 3) : 0;

    days.push({ date, count, week: w, day: d });
  }
}

function getLevel(count: number): number {
  if (count === 0) return 0;
  if (count <= 3) return 1;
  if (count <= 6) return 2;
  if (count <= 10) return 3;
  return 4;
}

function formatDate(date: Date): string {
  return date.toISOString().split("T")[0];
}

// Compute month labels
const monthLabels: { text: string; x: number }[] = [];
const monthNames = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
let lastMonth = -1;
for (const day of days) {
  if (day.day === 0 && day.date.getMonth() !== lastMonth) {
    lastMonth = day.date.getMonth();
    monthLabels.push({
      text: monthNames[day.date.getMonth()],
      x: day.week * totalSize,
    });
  }
}

const svgWidth = 52 * totalSize;
const svgHeight = 7 * totalSize + 20; // extra space for month labels
---

<section style="padding: 24px 0;">
  <h2 class="f3" style="margin: 0 0 16px;">Contributions</h2>
  <div style="overflow-x: auto;">
    <svg width={svgWidth} height={svgHeight} role="img" aria-label="Contribution heatmap">
      {/* Month labels */}
      {monthLabels.map((label) => (
        <text
          x={label.x}
          y={7 * totalSize + 14}
          fill="var(--fgColor-muted)"
          font-size="10"
          font-family="-apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif"
        >
          {label.text}
        </text>
      ))}

      {/* Day cells */}
      {days.map((day) => {
        const level = getLevel(day.count);
        return (
          <rect
            x={day.week * totalSize}
            y={day.day * totalSize}
            width={cellSize}
            height={cellSize}
            rx="2"
            fill={`var(--color-heatmap-${level})`}
          >
            <title>{formatDate(day.date)}: {day.count} event{day.count !== 1 ? "s" : ""}</title>
          </rect>
        );
      })}
    </svg>
  </div>
</section>
