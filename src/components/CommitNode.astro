---
import "../styles/timeline.css";

interface Props {
  event: {
    type: "commit";
    ts: string;
    repo: string;
    semantic: string | null;
    data: {
      sha: string;
      message: string;
      additions: number;
      deletions: number;
    };
  };
}

const { event } = Astro.props;
const { data, repo, semantic, ts } = event;
const shortSha = data.sha.slice(0, 7);
const firstLine = data.message.split("\n")[0];
const time = new Date(ts).toLocaleString("en-US", {
  month: "short",
  day: "numeric",
  hour: "2-digit",
  minute: "2-digit",
});
---

<div class="event-card" data-semantic={semantic}>
  <div style="display: flex; align-items: baseline; gap: 6px; flex-wrap: wrap;">
    <span class="event-sha">{shortSha}</span>
    <span style="color: var(--cp-fg-default); font-size: 13px;">{firstLine}</span>
    <span class="diff-stat">
      <span class="additions">+{data.additions}</span>
      <span class="deletions">-{data.deletions}</span>
    </span>
  </div>
  <div style="display: flex; gap: 10px; margin-top: 2px;">
    <span class="event-repo">{repo}</span>
    <span class="event-time">{time}</span>
  </div>
</div>
