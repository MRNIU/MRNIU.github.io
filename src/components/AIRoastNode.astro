---
import "../styles/timeline.css";

interface Props {
  event: {
    type: "ai_roast";
    ts: string;
    repo: null;
    semantic: null;
    data: {
      weekRange: string;
      content: string;
      stats: {
        totalCommits: number;
        topRepo: string;
      };
    };
  };
}

const { event } = Astro.props;
const { data, ts } = event;

const time = new Date(ts).toLocaleString("en-US", {
  month: "short",
  day: "numeric",
  hour: "2-digit",
  minute: "2-digit",
});
---

<div class="ai-roast-card">
  <div style="display: flex; align-items: baseline; gap: 8px; margin-bottom: 6px;">
    <span class="anomaly-label">&#x25C8; ai::roast</span>
    <span style="font-family: var(--cp-font-mono); font-size: 11px; color: var(--cp-fg-muted);">{data.weekRange}</span>
  </div>
  <p style="margin: 0 0 6px; font-size: 13px; line-height: 1.5; color: var(--cp-anomaly);">
    {data.content}
  </p>
  <div style="display: flex; gap: 12px; font-family: var(--cp-font-mono); font-size: 11px; color: var(--cp-fg-muted);">
    <span>{data.stats.totalCommits} commits</span>
    <span>{data.stats.topRepo}</span>
    <span>{time}</span>
  </div>
</div>
