---
import "../styles/timeline.css";

interface Props {
  event: {
    type: "issue_comment";
    ts: string;
    repo: string;
    semantic: string | null;
    data: {
      issueNumber: number;
      issueTitle: string;
      body: string;
    };
  };
}

const { event } = Astro.props;
const { data, repo, ts } = event;

const time = new Date(ts).toLocaleString("en-US", {
  month: "short",
  day: "numeric",
  hour: "2-digit",
  minute: "2-digit",
});

const issueUrl = `https://github.com/${repo}/issues/${data.issueNumber}`;
const repoUrl = `https://github.com/${repo}`;
---

<div class="event-card event-card--indented">
  <div style="display: flex; align-items: baseline; gap: 6px; flex-wrap: wrap;">
    <span class="event-time" style="color: var(--cp-fg-muted);">comment</span>
    <a class="event-ref" href={issueUrl} target="_blank" rel="noopener">#{data.issueNumber}</a>
    <span>{data.issueTitle}</span>
  </div>
  <p class="event-body">{data.body}</p>
  <div style="display: flex; gap: 10px; margin-top: 2px;">
    <a class="event-repo" href={repoUrl} target="_blank" rel="noopener">{repo}</a>
    <span class="event-time">{time}</span>
  </div>
</div>
