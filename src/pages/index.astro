---
import BaseLayout from "../layouts/BaseLayout.astro";
import Dashboard from "../components/Dashboard.astro";
import TopRepos from "../components/TopRepos.astro";
import Heatmap from "../components/Heatmap.astro";
import Sidebar from "../components/Sidebar.astro";
import EventCard from "../components/EventCard.astro";
import "../styles/global.css";
import "../styles/timeline.css";
import { getMessages, t } from "../i18n/index.ts";

import indexData from "../../data/index.json";
import marchData from "../../data/2026-03.json";

import { createRequire } from "node:module";
import path from "node:path";
import { fileURLToPath } from "node:url";
const configPath = path.resolve(process.cwd(), "devlog.config.cjs");
const require = createRequire(import.meta.url);
const config = require(configPath);
const locale = config.locale || "en";
const m = getMessages(locale);

const activeMonth = indexData.months[0]?.key || "2026-03";
const noDataMsg = t(m, "empty.noData");
const allMonthKeys = indexData.months.map((m: any) => m.key);
---
<BaseLayout title={`${t(m, "title")} — ${indexData.user}`}>
  <div class="top-section">
    <header style="padding: 48px 0 24px; text-align: center;">
      <h1 class="f1" style="margin: 0;">{t(m, "title")}</h1>
      <p class="color-fg-muted f4" style="margin: 4px 0 0;">{t(m, "subtitle", { user: indexData.user })}</p>
    </header>

    <Dashboard stats={indexData.stats} labels={{
      commits: t(m, "dashboard.commits"),
      prs: t(m, "dashboard.prs"),
      reviews: t(m, "dashboard.reviews"),
      issues: t(m, "dashboard.issues"),
      comments: t(m, "dashboard.comments"),
      repos: t(m, "dashboard.repos"),
    }} />
    <Heatmap months={indexData.months} />
    <TopRepos months={indexData.months} />
  </div>

  <section style="padding: 32px 0;">
    <h2 class="f3 timeline-title" style="margin: 0 0 16px;">{t(m, "timeline.title")}</h2>

    <button class="sidebar-toggle" id="sidebar-toggle">
      &#9776; {t(m, "sidebar.filtersToggle")}
    </button>

    <div class="timeline-layout">
      <Sidebar months={indexData.months} activeMonth={activeMonth} labels={{
        months: t(m, "sidebar.months"),
        filter: t(m, "sidebar.filter"),
        eventTypes: {
          commit: t(m, "eventTypes.commit"),
          pull_request: t(m, "eventTypes.pull_request"),
          review: t(m, "eventTypes.review"),
          issue: t(m, "eventTypes.issue"),
          issue_comment: t(m, "eventTypes.issue_comment"),
          ai_roast: t(m, "eventTypes.ai_roast"),
        },
      }} />

      <main class="timeline-main" id="timeline-main"
            data-no-data-msg={noDataMsg}
            data-all-months={JSON.stringify(allMonthKeys)}>
        <!-- First month rendered at build time -->
        <div class="month-section" data-month-section={activeMonth} id={`month-${activeMonth}`}>
          <h3 class="month-divider">{new Date(activeMonth + '-01').toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}</h3>
          {marchData.events.map((event: any) => (
            <div class="event-wrapper" data-event-type={event.type}>
              <EventCard event={event} />
            </div>
          ))}
        </div>
        <!-- Remaining months loaded dynamically on scroll -->
        <div id="scroll-sentinel" style="height: 1px;"></div>
      </main>
    </div>
  </section>

  <script>
    // ─── State ───
    const timelineMain = document.getElementById('timeline-main')!;
    const allMonths: string[] = JSON.parse(timelineMain.getAttribute('data-all-months')!);
    const loadedMonths = new Set<string>([allMonths[0]]);
    let loadingMonth = false;
    let nextMonthIndex = 1; // next month to load (allMonths is newest-first)

    // ─── Type Filtering ───
    const filters = document.querySelectorAll<HTMLInputElement>('[data-filter-type]');
    filters.forEach(checkbox => {
      checkbox.addEventListener('change', () => applyFilters());
    });

    function applyFilters() {
      const activeTypes = new Set<string>();
      filters.forEach(f => {
        if ((f as HTMLInputElement).checked) activeTypes.add(f.getAttribute('data-filter-type')!);
      });
      document.querySelectorAll<HTMLElement>('.event-wrapper').forEach(wrapper => {
        const type = wrapper.getAttribute('data-event-type')!;
        wrapper.style.display = activeTypes.has(type) ? '' : 'none';
      });
    }

    // ─── Mobile sidebar toggle ───
    const toggleBtn = document.getElementById('sidebar-toggle');
    const sidebar = document.getElementById('sidebar');
    if (toggleBtn && sidebar) {
      if (window.innerWidth < 1024) sidebar.classList.add('collapsed');
      toggleBtn.addEventListener('click', () => sidebar.classList.toggle('collapsed'));
    }

    // ─── Infinite scroll: load next month when sentinel is near viewport ───
    const sentinel = document.getElementById('scroll-sentinel')!;

    const scrollObserver = new IntersectionObserver(async (entries) => {
      if (!entries[0].isIntersecting || loadingMonth) return;
      await loadNextMonth();
    }, { rootMargin: '600px' });

    scrollObserver.observe(sentinel);

    async function loadNextMonth() {
      if (nextMonthIndex >= allMonths.length) {
        scrollObserver.disconnect();
        sentinel.remove();
        return;
      }
      loadingMonth = true;
      const monthKey = allMonths[nextMonthIndex];
      nextMonthIndex++;

      try {
        const resp = await fetch(`/data/${monthKey}.json`);
        if (!resp.ok) {
          loadingMonth = false;
          return;
        }
        const data = await resp.json();

        // Build month section
        const section = document.createElement('div');
        section.className = 'month-section';
        section.setAttribute('data-month-section', monthKey);
        section.id = `month-${monthKey}`;

        const header = document.createElement('h3');
        header.className = 'month-divider';
        const d = new Date(monthKey + '-01');
        header.textContent = d.toLocaleDateString('en-US', { year: 'numeric', month: 'long' });
        section.appendChild(header);

        data.events.forEach((event: any) => {
          const wrapper = document.createElement('div');
          wrapper.className = 'event-wrapper';
          wrapper.setAttribute('data-event-type', event.type);
          wrapper.innerHTML = renderEventCard(event);
          section.appendChild(wrapper);
        });

        // Insert before sentinel
        sentinel.parentNode!.insertBefore(section, sentinel);
        loadedMonths.add(monthKey);

        // Observe new section for sidebar sync
        sectionObserver.observe(section);

        // Apply current filters to new content
        applyFilters();
      } catch (e) {
        console.error('Failed to load month:', monthKey, e);
      }
      loadingMonth = false;
    }

    // ─── Sidebar sync: highlight active month on scroll ───
    const monthBtns = document.querySelectorAll<HTMLButtonElement>('.month-btn');
    let programmaticScroll = false;

    const sectionObserver = new IntersectionObserver((entries) => {
      if (programmaticScroll) return;
      // Find the topmost visible section
      let topSection: Element | null = null;
      let topY = Infinity;
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const y = entry.boundingClientRect.top;
          if (y < topY) {
            topY = y;
            topSection = entry.target;
          }
        }
      });
      if (topSection) {
        const monthKey = (topSection as HTMLElement).getAttribute('data-month-section');
        if (monthKey) setActiveMonth(monthKey);
      }
    }, { rootMargin: '-10% 0px -80% 0px' });

    // Observe the initial month section
    document.querySelectorAll('.month-section').forEach(s => sectionObserver.observe(s));

    function setActiveMonth(monthKey: string) {
      monthBtns.forEach(b => {
        b.classList.toggle('active', b.getAttribute('data-month') === monthKey);
      });
      // Scroll active button into view within sidebar
      const activeBtn = document.querySelector(`.month-btn[data-month="${monthKey}"]`);
      if (activeBtn) {
        activeBtn.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
      }
    }

    // ─── Sidebar click: scroll to month (load if needed) ───
    monthBtns.forEach(btn => {
      btn.addEventListener('click', async () => {
        const monthKey = btn.getAttribute('data-month');
        if (!monthKey) return;

        // Load all months up to the clicked one if not loaded yet
        while (!loadedMonths.has(monthKey) && nextMonthIndex < allMonths.length) {
          await loadNextMonth();
        }

        const section = document.getElementById(`month-${monthKey}`);
        if (section) {
          programmaticScroll = true;
          setActiveMonth(monthKey);
          section.scrollIntoView({ behavior: 'smooth' });
          // Reset flag after scroll settles
          setTimeout(() => { programmaticScroll = false; }, 1000);
        }
      });
    });

    // ─── Render helpers ───
    function renderEventCard(event: any): string {
      const time = new Date(event.ts).toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
      const semantic = event.semantic || '';

      switch (event.type) {
        case 'commit':
          return `<div class="event-card" data-semantic="${semantic}">
              <div style="display: flex; justify-content: space-between; align-items: baseline;">
                <div>
                  <span class="event-sha">${event.data.sha.slice(0, 7)}</span>
                  <span style="margin-left: 8px;">${escapeHtml(event.data.message)}</span>
                </div>
                <span class="diff-stat"><span class="additions">+${event.data.additions}</span> <span class="deletions">-${event.data.deletions}</span></span>
              </div>
              <div style="margin-top: 4px;">
                <span class="event-repo">${event.repo}</span>
                <span class="event-time" style="margin-left: 8px;">${time}</span>
              </div>
            </div>`;

        case 'pull_request': {
          const stateColor = event.data.state === 'merged' ? '#8957e5' : event.data.state === 'open' ? '#238636' : '#da3633';
          return `<div class="event-card" data-semantic="${semantic}">
              <div style="display: flex; align-items: baseline; gap: 8px;">
                <span class="Label" style="background: ${stateColor}; color: white; padding: 2px 8px; border-radius: 12px; font-size: 12px;">${event.data.state}</span>
                <span style="font-weight: 600;">#${event.data.number} ${escapeHtml(event.data.title)}</span>
              </div>
              ${event.data.body ? `<p style="margin: 8px 0 0; color: var(--fgColor-muted); font-size: 13px; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">${escapeHtml(event.data.body)}</p>` : ''}
              <div style="margin-top: 4px;">
                <span class="event-repo">${event.repo}</span>
                <span class="event-time" style="margin-left: 8px;">${time}</span>
              </div>
            </div>`;
        }

        case 'review': {
          const stateColors: Record<string,string> = { 'APPROVED': '#238636', 'CHANGES_REQUESTED': '#da3633', 'COMMENTED': '#768390' };
          const color = stateColors[event.data.state] || '#768390';
          const inlineHtml = (event.data.inlineComments || []).map((c: any) =>
            `<div class="review-inline"><code>${escapeHtml(c.path)}:${c.line}</code><br/>${escapeHtml(c.body)}</div>`
          ).join('');
          return `<div class="event-card">
              <div style="display: flex; align-items: baseline; gap: 8px;">
                <span class="Label" style="background: ${color}; color: white; padding: 2px 8px; border-radius: 12px; font-size: 12px;">${event.data.state}</span>
                <span>PR #${event.data.prNumber}: ${escapeHtml(event.data.prTitle)}</span>
              </div>
              ${event.data.body ? `<p style="margin: 8px 0 0; font-size: 13px;">${escapeHtml(event.data.body)}</p>` : ''}
              ${inlineHtml}
              <div style="margin-top: 4px;">
                <span class="event-repo">${event.repo}</span>
                <span class="event-time" style="margin-left: 8px;">${time}</span>
              </div>
            </div>`;
        }

        case 'issue': {
          const icon = event.data.state === 'open' ? '\u{1F7E2}' : '\u{1F7E3}';
          return `<div class="event-card" data-semantic="${semantic}">
              <div style="display: flex; align-items: baseline; gap: 8px;">
                <span>${icon}</span>
                <span style="font-weight: 600;">#${event.data.number} ${escapeHtml(event.data.title)}</span>
              </div>
              ${event.data.body ? `<p style="margin: 8px 0 0; color: var(--fgColor-muted); font-size: 13px; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">${escapeHtml(event.data.body)}</p>` : ''}
              <div style="margin-top: 4px;">
                <span class="event-repo">${event.repo}</span>
                <span class="event-time" style="margin-left: 8px;">${time}</span>
              </div>
            </div>`;
        }

        case 'issue_comment':
          return `<div class="event-card">
              <div style="font-size: 13px; color: var(--fgColor-muted);">
                Commented on <span style="font-weight: 600;">#${event.data.issueNumber}: ${escapeHtml(event.data.issueTitle)}</span>
              </div>
              <p style="margin: 8px 0 0; font-size: 13px;">${escapeHtml(event.data.body)}</p>
              <div style="margin-top: 4px;">
                <span class="event-repo">${event.repo}</span>
                <span class="event-time" style="margin-left: 8px;">${time}</span>
              </div>
            </div>`;

        case 'ai_roast':
          return `<div class="ai-roast-card">
              <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
                <span style="font-size: 24px;">\u{1F916}</span>
                <span class="text-bold">AI Weekly Roast</span>
                <span class="event-time">${event.data.weekRange}</span>
              </div>
              <p style="margin: 0; font-size: 14px; line-height: 1.6;">${escapeHtml(event.data.content)}</p>
              <div style="margin-top: 8px; font-size: 12px; color: var(--fgColor-muted);">
                ${event.data.stats.totalCommits} commits \u00B7 Top repo: ${event.data.stats.topRepo}
              </div>
            </div>`;

        default:
          return '';
      }
    }

    function escapeHtml(str: string): string {
      if (!str) return '';
      return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }
  </script>
</BaseLayout>
